@startuml Komponenten

left to right direction

actor RESTClient
actor GraphQLClient

node "patient" {
  [patient_get_controller]
  [patient_write_controller]
  [schema]

  [patient_read_service]
  [patient_write_service]

  [patient_repository]

  [mailer]
}


cloud {
    [SQLAlchemy]
}

cloud {
    [smtp]
}

database "DB patient" {
    [Tabelle patient]
    [Tabelle adresse]
    [Tabelle rechnung]
}

node {
    [Mailserver]
}

RESTClient ~~> [patient_get_controller]
RESTClient ~~> [patient_write_controller]
GraphQLClient ~~> [schema]

[patient_get_controller] ..> [patient_read_service]
[patient_write_controller] ..> [patient_write_service]
[schema] ..> [patient_read_service]
[schema] ..> [patient_write_service]
[patient_read_service] ..> [patient_repository]
[patient_write_service] ..> [patient_repository]

[patient_repository] ~~> [SQLAlchemy]
[SQLAlchemy] ~~> [Tabelle patient]
[SQLAlchemy] ~~> [Tabelle adresse]
[SQLAlchemy] ~~> [Tabelle rechnung]

[patient_write_service] ..> [mailer]
[mailer] ~~> [smtp]
[smtp] ~~> [Mailserver]

footer (c) Jürgen Zimmermann

@enduml
